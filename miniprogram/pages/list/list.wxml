<!--pages/list/list.wxml - 机房列表页（支持「我的录入」与「全部」切换）-->
<view class="page-list">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <t-search
      value="{{keyword}}"
      placeholder="搜索机房名称/地址"
      bind:change="onSearchChange"
      bind:confirm="onSearchConfirm"
      bind:clear="onSearchClear"
      action-text=""
    />
  </view>

  <!-- 模式切换：我的录入 / 全部 -->
  <view class="mode-tabs">
    <view
      class="mode-tab {{listMode === 'mine' ? 'mode-tab-active' : ''}}"
      bindtap="onModeChange"
      data-mode="mine"
    >
      我的录入
    </view>
    <view
      class="mode-tab {{listMode === 'all' ? 'mode-tab-active' : ''}}"
      bindtap="onModeChange"
      data-mode="all"
    >
      全部记录
    </view>
  </view>

  <!-- 状态筛选标签 -->
  <scroll-view scroll-x class="filter-scroll">
    <view class="filter-tabs">
      <view
        wx:for="{{filterTags}}"
        wx:key="value"
        class="filter-tag {{activeFilter === item.value ? 'filter-active' : ''}}"
        bindtap="onFilterTap"
        data-value="{{item.value}}"
      >
        {{item.label}}
      </view>
    </view>
  </scroll-view>

  <!-- 列表 -->
  <view class="list-container">
    <!-- 加载中 -->
    <view wx:if="{{loading && list.length === 0}}" class="loading-wrapper">
      <t-loading text="加载中..." />
    </view>

    <!-- 空状态 -->
    <view wx:elif="{{list.length === 0}}" class="empty-state">
      <t-empty
        description="{{listMode === 'mine' ? '您还没有录入任何机房' : '暂无记录'}}"
        icon="search"
      />
      <view wx:if="{{listMode === 'mine'}}" class="empty-tip">点击底部「+」按钮录入第一个机房</view>
    </view>

    <!-- 有数据 -->
    <view wx:else>
      <view
        wx:for="{{list}}"
        wx:key="_id"
        class="card dc-card"
        bindtap="goDetail"
        data-id="{{item._id}}"
      >
        <!-- 卡片头部：名称 + 状态 -->
        <view class="dc-card-header">
          <view class="dc-name">{{item.name || '未命名机房'}}</view>
          <view class="dc-tag tag-{{item.status || 'new'}}">{{item.statusText}}</view>
        </view>

        <!-- 卡片主体：关键信息 -->
        <view class="dc-card-body">
          <view class="dc-info-row" wx:if="{{item.city || item.address}}">
            <t-icon name="location" size="28rpx" color="#64748B" />
            <text class="dc-info-text">{{item.city || item.address}}</text>
          </view>
          <view class="dc-info-row" wx:if="{{item.mainCoolingType}}">
            <t-icon name="server" size="28rpx" color="#64748B" />
            <text class="dc-info-text">{{item.mainCoolingType}}</text>
          </view>
          <view class="dc-info-row" wx:if="{{item.availablePower}}">
            <t-icon name="flash" size="28rpx" color="#64748B" />
            <text class="dc-info-text num-highlight">{{item.availablePower}} MW</text>
          </view>
          <view class="dc-info-row" wx:if="{{item.totalCabinets}}">
            <t-icon name="app" size="28rpx" color="#64748B" />
            <text class="dc-info-text">{{item.totalCabinets}} 个机柜</text>
          </view>
        </view>

        <!-- 卡片底部：时间 + 录入人 -->
        <view class="dc-card-footer">
          <text class="dc-date">{{item.visitDate || item.createdAt}}</text>
          <text class="dc-creator">{{item.creatorLabel}}</text>
        </view>
      </view>

      <!-- 加载更多 -->
      <view wx:if="{{hasMore}}" class="load-more" bindtap="loadMore">
        <t-loading wx:if="{{loadingMore}}" text="加载中..." size="40rpx" />
        <text wx:else class="load-more-text">点击加载更多</text>
      </view>
      <view wx:if="{{!hasMore && list.length > 0}}" class="load-more">
        <text class="load-more-text load-end">— 已加载全部 —</text>
      </view>
    </view>
  </view>

  <!-- 浮动新建按钮 -->
  <view class="fab" bindtap="goForm">
    <t-icon name="add" size="52rpx" color="#FFFFFF" />
  </view>

  <watermark />
</view>
