/* pages/list/list.wxss */
.page-list {
  min-height: 100vh;
  padding-bottom: 140rpx;
}

.search-bar {
  padding: var(--spacing-sm) var(--spacing-md);
  background: var(--color-card);
}

/* 筛选 */
.filter-scroll {
  white-space: nowrap;
  background: var(--color-card);
  border-bottom: 2rpx solid var(--color-border);
}

.filter-tabs {
  display: inline-flex;
  padding: 0 var(--spacing-md) var(--spacing-sm);
  gap: var(--spacing-xs);
}

.filter-tag {
  display: inline-block;
  padding: 8rpx 24rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
  background: var(--color-bg);
  border-radius: 32rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.filter-active {
  color: var(--color-primary);
  background: rgba(30, 58, 95, 0.08);
  border-color: var(--color-primary);
  font-weight: 500;
}

/* 列表 */
.list-container {
  padding: var(--spacing-sm) var(--spacing-md);
}

.dc-card {
  padding: var(--spacing-md);
  margin-bottom: var(--spacing-sm);
}

.dc-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-xs);
}

.dc-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: var(--spacing-sm);
}

.dc-tag {
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.dc-card-body {
  display: flex;
  flex-wrap: wrap;
  gap: 4rpx var(--spacing-md);
  margin-bottom: var(--spacing-xs);
}

.dc-info-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.dc-info-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.dc-card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.dc-date {
  font-size: 22rpx;
  color: var(--color-text-placeholder);
  font-family: 'JetBrains Mono', 'SF Mono', monospace;
}

.dc-creator {
  font-size: 22rpx;
  color: var(--color-text-placeholder);
}

/* 加载更多 */
.load-more {
  display: flex;
  justify-content: center;
  padding: 32rpx 0;
}

.load-more-text {
  font-size: 24rpx;
  color: var(--color-text-placeholder);
}

.load-end {
  color: var(--color-border);
}

/* 浮动按钮 */
.fab {
  position: fixed;
  right: var(--spacing-lg);
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  width: 100rpx;
  height: 100rpx;
  background: var(--color-accent);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 16px rgba(232, 132, 60, 0.4);
}

/* ===== 模式切换 Tab（我的录入 / 全部记录）====== */
.mode-tabs {
  display: flex;
  background: #FFFFFF;
  padding: 0 24rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.mode-tab {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  padding: 20rpx 0;
  position: relative;
  transition: color 0.2s;
}

.mode-tab-active {
  color: var(--color-primary);
  font-weight: 600;
}

.mode-tab-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 80rpx;
  height: 4rpx;
  background: var(--color-primary);
  border-radius: 2rpx;
}

/* ===== 空状态提示 ===== */
.empty-tip {
  text-align: center;
  font-size: 26rpx;
  color: var(--color-text-placeholder);
  margin-top: 16rpx;
  padding: 0 40rpx;
}

/* ===== 状态标签颜色 ===== */
.tag-new { background: #EFF6FF; color: #3B82F6; }
.tag-visited { background: #F0FDF4; color: #22C55E; }
.tag-negotiating { background: #FFFBEB; color: #F59E0B; }
.tag-contracted { background: #F0FDF4; color: #16A34A; }
.tag-rejected { background: #FEF2F2; color: #EF4444; }
