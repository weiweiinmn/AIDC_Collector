/* pages/detail/detail.wxss */
.page-detail {
  min-height: 100vh;
  background: #F5F7FA;
  padding-bottom: 160rpx;
}

/* 头部 */
.detail-header {
  background: linear-gradient(135deg, #1E3A5F, #2A5082);
  padding: 40rpx 32rpx 32rpx;
}

.detail-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 16rpx;
}

.detail-tags {
  display: flex;
  gap: 12rpx;
}

.dc-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.tag-new { background: rgba(232, 132, 60, 0.2); color: #E8843C; }
.tag-visited { background: rgba(0, 180, 42, 0.2); color: #00B42A; }
.tag-negotiating { background: rgba(0, 82, 217, 0.2); color: #0052D9; }
.tag-contracted { background: rgba(0, 180, 42, 0.2); color: #00B42A; }
.tag-rejected { background: rgba(227, 77, 89, 0.2); color: #E34D59; }
.tag-source { background: rgba(255, 255, 255, 0.15); color: rgba(255, 255, 255, 0.7); }

/* 区块 */
.section {
  margin: 24rpx 24rpx 0;
}

.section-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #1E3A5F;
  margin-bottom: 16rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #E8843C;
}

.card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 信息行 */
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F7FA;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #6B7280;
  flex-shrink: 0;
}

.info-value {
  font-size: 26rpx;
  color: #1F2937;
  text-align: right;
  max-width: 60%;
  word-break: break-all;
}

.num-highlight {
  color: #E8843C;
  font-weight: bold;
  font-family: 'SF Mono', monospace;
}

/* 参数网格 */
.param-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.param-item {
  width: calc(50% - 12rpx);
  background: #F9FAFB;
  border-radius: 12rpx;
  padding: 20rpx;
  box-sizing: border-box;
}

.param-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #1F2937;
  margin-bottom: 4rpx;
  word-break: break-all;
}

.param-unit {
  font-size: 22rpx;
  color: #9CA3AF;
}

/* 备注 */
.notes-text {
  font-size: 26rpx;
  color: #4B5563;
  line-height: 1.8;
}

/* 照片网格 */
.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.photo-item {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
}

/* 修改历史 */
.history-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F7FA;
}

.history-item:last-child {
  border-bottom: none;
}

.history-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.history-field {
  font-size: 26rpx;
  font-weight: bold;
  color: #1E3A5F;
}

.history-time {
  font-size: 22rpx;
  color: #9CA3AF;
}

.history-change {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.history-old {
  font-size: 24rpx;
  color: #9CA3AF;
  text-decoration: line-through;
}

.history-new {
  font-size: 24rpx;
  color: #00B42A;
  font-weight: bold;
}

.history-user {
  font-size: 22rpx;
  color: #9CA3AF;
}

/* 底部元信息 */
.section-footer {
  margin-top: 8rpx;
}

.record-meta {
  font-size: 22rpx;
  color: #9CA3AF;
  text-align: center;
}

.meta-divider {
  color: #D1D5DB;
  margin: 0 8rpx;
}

/* 操作按钮 */
.detail-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 24rpx;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.detail-actions .t-button {
  flex: 1;
}

/* ===== 重点信息概览卡 ===== */
.hero-card-wrapper {
  margin: 24rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(30, 58, 95, 0.1);
  overflow: hidden;
}

.hero-row {
  display: flex;
  align-items: stretch;
  border-bottom: 1rpx solid #F1F5F9;
}

.hero-row:last-child {
  border-bottom: none;
}

.hero-item {
  flex: 1;
  padding: 24rpx 16rpx;
  text-align: center;
}

.hero-sep {
  width: 1rpx;
  background: #F1F5F9;
  flex-shrink: 0;
}

.hero-label {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-bottom: 8rpx;
  font-weight: normal;
}

.hero-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #1E3A5F;
  line-height: 1.2;
}

.hero-value.small {
  font-size: 26rpx;
  font-weight: 600;
}

.hero-value.no-overflow {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hero-unit {
  font-size: 22rpx;
  color: #6B7280;
  font-weight: normal;
  margin-left: 2rpx;
}

/* 标签徽章 */
.badge {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 600;
  line-height: 1.4;
}

.badge-yes { background: #DCFCE7; color: #16A34A; }
.badge-no  { background: #FEE2E2; color: #EF4444; }
.badge-warn { background: #FEF9C3; color: #CA8A04; }
