/* pages/form/basic.wxss - 添加机房表单重设计样式 */

/* ==================== 页面容器 ==================== */
.page-form {
  min-height: 100vh;
  background: #F5F7FA;
  padding-bottom: 180rpx;
}

/* ==================== 通用区块 ==================== */
.section {
  padding: 0 24rpx 20rpx;
}

.section-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 28rpx 0 12rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E3A5F;
}

.section-hint {
  font-size: 22rpx;
  font-weight: 400;
  color: #9CA3AF;
  margin-left: 6rpx;
}

.card {
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
}

/* ==================== 字段行（核心布局）==================== */
.field-row {
  display: flex;
  flex-direction: column;
  padding: 20rpx 28rpx;
  border-bottom: 1rpx solid #F1F5F9;
  min-height: 96rpx;
  justify-content: center;
}

.field-row:last-child {
  border-bottom: none;
}

/* 字段标签 */
.field-label {
  font-size: 26rpx;
  color: #6B7280;
  margin-bottom: 10rpx;
  line-height: 1.4;
  display: flex;
  align-items: center;
}

/* 必填星标 */
.required-star {
  color: #DC2626;
  font-size: 26rpx;
  margin-right: 4rpx;
  line-height: 1.4;
}

/* ==================== 输入控件 ==================== */

/* 普通文本输入 */
.field-input {
  width: 100%;
  font-size: 28rpx;
  color: #1F2937;
}

/* 数字输入（带单位） */
.input-wrap {
  display: flex;
  align-items: center;
  width: 100%;
}

.field-input-digit {
  flex: 1;
  font-size: 28rpx;
  color: #1F2937;
  min-width: 0;
}

/* 单位后缀 */
.unit-suffix {
  font-size: 26rpx;
  color: #9CA3AF;
  padding: 0 12rpx 0 8rpx;
  white-space: nowrap;
  flex-shrink: 0;
}

/* picker 选择器容器 */
.field-picker {
  width: 100%;
}

/* 日期选择器容器 */
.date-picker-wrap {
  width: 100%;
}

/* 多行文本 */
.field-textarea {
  width: 100%;
  font-size: 28rpx;
  color: #1F2937;
}

/* ==================== 快速信息区 ==================== */
.section-quick {
  padding: 0 24rpx 0;
}

.card-quick {
  background: #FFFFFF;
  border-radius: 16rpx;
  border: 1rpx solid #E5E7EB;
  overflow: hidden;
}

/* ==================== 展开/收起按钮 ==================== */
.expand-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx 0;
  font-size: 26rpx;
  color: #1E3A5F;
  background: #F5F7FA;
  margin: 0 24rpx;
  border-radius: 12rpx;
  border: 1rpx solid #E5E7EB;
}

/* ==================== 折叠分组模块 ==================== */

/* 折叠区标题栏 */
.collapse-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 24rpx 0 12rpx;
  cursor: pointer;
}

.collapse-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E3A5F;
  flex: 1;
}

/* 已填数量角标 */
.collapse-badge {
  font-size: 22rpx;
  color: #9CA3AF;
  background: #F1F5F9;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  font-weight: 400;
}

/* 折叠状态（隐藏内容）*/
.card.collapsed {
  display: none;
}

/* ==================== 照片区 ==================== */
.photo-section {
  padding: 24rpx 28rpx;
}

/* ==================== 底部提交栏 ==================== */
.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

/* ==================== 通用数字高亮 ==================== */
.num-highlight {
  color: #1E3A5F;
  font-weight: 600;
  font-size: 32rpx;
}

/* ==================== 第一屏字段标签特殊处理 ==================== */
/* 确保必填标签行间距与输入控件协调 */
.card-quick .field-row:first-child {
  padding-top: 24rpx;
}

.card-quick .field-row:last-child {
  padding-bottom: 24rpx;
}
