<!--pages/form/basic.wxml-->
<view class="page-form">
  <!-- 一、基础信息 -->
  <view class="section">
    <view class="section-label">一、基础信息</view>
    <view class="card">
      <view class="form-group">
        <view class="form-label form-required">数据中心名称</view>
        <t-input value="{{form.name}}" placeholder="如 Equinix SG2" bind:change="onFieldChange" data-field="name" maxlength="100" />
      </view>
      <view class="form-group">
        <view class="form-label form-required">地址（国家/城市/园区）</view>
        <t-input value="{{form.address}}" placeholder="详细地址" bind:change="onFieldChange" data-field="address" maxlength="200" />
      </view>
      <view class="form-group">
        <view class="form-label form-required">采集区域</view>
        <t-picker value="{{form.region}}" title="选择采集区域" options="{{regionOptions}}" bind:confirm="onRegionConfirm" id="picker-region">
          <t-cell title="采集区域" value="{{regionLabel || '请选择'}}" arrow bind:tap="onRegionTap" />
        </t-picker>
      </view>
      <view class="form-row">
        <view class="form-group form-group-half">
          <view class="form-label">产权归属</view>
          <t-picker value="{{form.ownership}}" title="选择产权归属" options="{{pickerOptions.ownership}}" bind:confirm="onPickerConfirm" data-field="ownership" id="picker-ownership">
            <t-cell title="产权归属" value="{{form.ownership || '请选择'}}" arrow bind:tap="onPickerTap" data-field="ownership" />
          </t-picker>
        </view>
        <view class="form-group form-group-half">
          <view class="form-label">预计交付时间</view>
          <t-input value="{{form.expectedDelivery}}" placeholder="年月，如2026-06" bind:change="onFieldChange" data-field="expectedDelivery" maxlength="10" />
        </view>
      </view>
    </view>
  </view>

  <!-- 二、机柜资源 -->
  <view class="section">
    <view class="section-label">二、机柜资源</view>
    <view class="card">
      <view class="form-row">
        <view class="form-group form-group-half">
          <view class="form-label">总机柜数量</view>
          <view class="input-with-unit">
            <t-input value="{{form.totalCabinets}}" placeholder="数量" type="number" bind:change="onFieldChange" data-field="totalCabinets" />
            <text class="input-unit">{{unitFields.totalCabinets}}</text>
          </view>
        </view>
        <view class="form-group form-group-half">
          <view class="form-label">当前可提供数量</view>
          <view class="input-with-unit">
            <t-input value="{{form.availableCabinets}}" placeholder="可立即交付" type="number" bind:change="onFieldChange" data-field="availableCabinets" />
            <text class="input-unit">{{unitFields.availableCabinets}}</text>
          </view>
        </view>
      </view>
      <view class="form-row">
        <view class="form-group form-group-half">
          <view class="form-label">最高可支撑功率</view>
          <view class="input-with-unit">
            <t-input value="{{form.maxCabinetPower}}" placeholder="功率" type="digit" bind:change="onFieldChange" data-field="maxCabinetPower" />
            <text class="input-unit">{{unitFields.maxCabinetPower}}</text>
          </view>
        </view>
        <view class="form-group form-group-half">
          <view class="form-label">能否连续布置</view>
          <t-picker value="{{form.continuousCabinets}}" title="选择" options="{{pickerOptions.continuousCabinets}}" bind:confirm="onPickerConfirm" data-field="continuousCabinets" id="picker-continuousCabinets">
            <t-cell title="能否连续布置" value="{{form.continuousCabinets || '请选择'}}" arrow bind:tap="onPickerTap" data-field="continuousCabinets" />
          </t-picker>
        </view>
      </view>
      <view class="form-group">
        <view class="form-label">是否支持物理隔离</view>
        <t-picker value="{{form.physicalIsolation}}" title="选择" options="{{pickerOptions.physicalIsolation}}" bind:confirm="onPickerConfirm" data-field="physicalIsolation" id="picker-physicalIsolation">
          <t-cell title="物理隔离" value="{{form.physicalIsolation || '请选择'}}" arrow bind:tap="onPickerTap" data-field="physicalIsolation" />
        </t-picker>
      </view>
    </view>
  </view>

  <!-- 三、电力系统 -->
  <view class="section">
    <view class="section-label">三、电力系统</view>
    <view class="card">
      <view class="form-row">
        <view class="form-group form-group-half">
          <view class="form-label">市电总容量</view>
          <view class="input-with-unit">
            <t-input value="{{form.mainsCapacity}}" placeholder="容量" type="digit" bind:change="onFieldChange" data-field="mainsCapacity" />
            <text class="input-unit">{{unitFields.mainsCapacity}}</text>
          </view>
        </view>
        <view class="form-group form-group-half">
          <view class="form-label">当前可用电力</view>
          <view class="input-with-unit">
            <t-input value="{{form.availablePower}}" placeholder="可立即使用" type="digit" bind:change="onFieldChange" data-field="availablePower" />
            <text class="input-unit">{{unitFields.availablePower}}</text>
          </view>
        </view>
      </view>
      <view class="form-row">
        <view class="form-group form-group-half">
          <view class="form-label">可扩容电力上限</view>
          <view class="input-with-unit">
            <t-input value="{{form.expandablePower}}" placeholder="未来最大" type="digit" bind:change="onFieldChange" data-field="expandablePower" />
            <text class="input-unit">{{unitFields.expandablePower}}</text>
          </view>
        </view>
        <view class="form-group form-group-half">
          <view class="form-label">变压器配置</view>
          <t-picker value="{{form.transformerConfig}}" title="选择" options="{{pickerOptions.transformerConfig}}" bind:confirm="onPickerConfirm" data-field="transformerConfig" id="picker-transformerConfig">
            <t-cell title="变压器配置" value="{{form.transformerConfig || '请选择'}}" arrow bind:tap="onPickerTap" data-field="transformerConfig" />
          </t-picker>
        </view>
      </view>
      <view class="form-row">
        <view class="form-group form-group-half">
          <view class="form-label">单台变压器容量</view>
          <view class="input-with-unit">
            <t-input value="{{form.transformerCapacity}}" placeholder="容量" type="digit" bind:change="onFieldChange" data-field="transformerCapacity" />
            <text class="input-unit">{{unitFields.transformerCapacity}}</text>
          </view>
        </view>
        <view class="form-group form-group-half">
          <view class="form-label">柴发冗余等级</view>
          <t-input value="{{form.generatorRedundancy}}" placeholder="如 N+1" bind:change="onFieldChange" data-field="generatorRedundancy" maxlength="10" />
        </view>
      </view>
      <view class="form-row">
        <view class="form-group form-group-half">
          <view class="form-label">柴发储油时长</view>
          <view class="input-with-unit">
            <t-input value="{{form.generatorFuelHours}}" placeholder="时长" type="digit" bind:change="onFieldChange" data-field="generatorFuelHours" />
            <text class="input-unit">{{unitFields.generatorFuelHours}}</text>
          </view>
        </view>
        <view class="form-group form-group-half">
          <view class="form-label">UPS配置</view>
          <t-picker value="{{form.upsConfig}}" title="选择" options="{{pickerOptions.upsConfig}}" bind:confirm="onPickerConfirm" data-field="upsConfig" id="picker-upsConfig">
            <t-cell title="UPS配置" value="{{form.upsConfig || '请选择'}}" arrow bind:tap="onPickerTap" data-field="upsConfig" />
          </t-picker>
        </view>
      </view>
      <view class="form-row">
        <view class="form-group form-group-half">
          <view class="form-label">UPS电池后备时间</view>
          <view class="input-with-unit">
            <t-input value="{{form.upsBatteryMinutes}}" placeholder="分钟" type="digit" bind:change="onFieldChange" data-field="upsBatteryMinutes" />
            <text class="input-unit">{{unitFields.upsBatteryMinutes}}</text>
          </view>
        </view>
        <view class="form-group form-group-half">
          <view class="form-label">电力可用性SLA</view>
          <t-input value="{{form.powerSLA}}" placeholder="99.99% / 99.999%" bind:change="onFieldChange" data-field="powerSLA" maxlength="10" />
        </view>
      </view>
      <view class="form-group">
        <view class="form-label">是否配备高密度母线</view>
        <t-picker value="{{form.highDensityBusway}}" title="选择" options="{{pickerOptions.highDensityBusway}}" bind:confirm="onPickerConfirm" data-field="highDensityBusway" id="picker-highDensityBusway">
          <t-cell title="高密度母线" value="{{form.highDensityBusway || '请选择'}}" arrow bind:tap="onPickerTap" data-field="highDensityBusway" />
        </t-picker>
      </view>
      <view class="form-group">
        <view class="form-label">是否配备BBU/超级电容</view>
        <t-picker value="{{form.bbuSuperCapacitor}}" title="选择" options="{{pickerOptions.bbuSuperCapacitor}}" bind:confirm="onPickerConfirm" data-field="bbuSuperCapacitor" id="picker-bbuSuperCapacitor">
          <t-cell title="BBU/超级电容" value="{{form.bbuSuperCapacitor || '请选择'}}" arrow bind:tap="onPickerTap" data-field="bbuSuperCapacitor" />
        </t-picker>
      </view>
    </view>
  </view>

  <!-- 四、制冷系统 -->
  <view class="section">
    <view class="section-label">四、制冷系统</view>
    <view class="card">
      <view class="form-group">
        <view class="form-label">主制冷方式</view>
        <t-input value="{{form.mainCoolingType}}" placeholder="如 水冷/风冷/液冷" bind:change="onFieldChange" data-field="mainCoolingType" maxlength="20" />
      </view>
      <view class="form-row">
        <view class="form-group form-group-half">
          <view class="form-label">支持冷板式液冷</view>
          <t-picker value="{{form.coldPlateLiquid}}" title="选择" options="{{pickerOptions.coldPlateLiquid}}" bind:confirm="onPickerConfirm" data-field="coldPlateLiquid" id="picker-coldPlateLiquid">
            <t-cell title="冷板式液冷" value="{{form.coldPlateLiquid || '请选择'}}" arrow bind:tap="onPickerTap" data-field="coldPlateLiquid" />
          </t-picker>
        </view>
        <view class="form-group form-group-half">
          <view class="form-label">如无液冷能否改造</view>
          <t-picker value="{{form.liquidCoolRetrofit}}" title="选择" options="{{pickerOptions.liquidCoolRetrofit}}" bind:confirm="onPickerConfirm" data-field="liquidCoolRetrofit" id="picker-liquidCoolRetrofit">
            <t-cell title="液冷改造" value="{{form.liquidCoolRetrofit || '请选择'}}" arrow bind:tap="onPickerTap" data-field="liquidCoolRetrofit" />
          </t-picker>
        </view>
      </view>
      <view class="form-row">
        <view class="form-group form-group-half">
          <view class="form-label">液冷改造周期</view>
          <view class="input-with-unit">
            <t-input value="{{form.liquidCoolPeriod}}" placeholder="月数" type="number" bind:change="onFieldChange" data-field="liquidCoolPeriod" />
            <text class="input-unit">{{unitFields.liquidCoolPeriod}}</text>
          </view>
        </view>
        <view class="form-group form-group-half">
          <view class="form-label">是否配备CDU</view>
          <t-picker value="{{form.hasCDU}}" title="选择" options="{{pickerOptions.hasCDU}}" bind:confirm="onPickerConfirm" data-field="hasCDU" id="picker-hasCDU">
            <t-cell title="CDU" value="{{form.hasCDU || '请选择'}}" arrow bind:tap="onPickerTap" data-field="hasCDU" />
          </t-picker>
        </view>
      </view>
      <view class="form-row">
        <view class="form-group form-group-half">
          <view class="form-label">冷冻水供水温度</view>
          <view class="input-with-unit">
            <t-input value="{{form.chilledWaterSupplyTemp}}" placeholder="温度" type="digit" bind:change="onFieldChange" data-field="chilledWaterSupplyTemp" />
            <text class="input-unit">{{unitFields.chilledWaterSupplyTemp}}</text>
          </view>
        </view>
        <view class="form-group form-group-half">
          <view class="form-label">冷冻水回水温度</view>
          <view class="input-with-unit">
            <t-input value="{{form.chilledWaterReturnTemp}}" placeholder="温度" type="digit" bind:change="onFieldChange" data-field="chilledWaterReturnTemp" />
            <text class="input-unit">{{unitFields.chilledWaterReturnTemp}}</text>
          </view>
        </view>
      </view>
      <view class="form-row">
        <view class="form-group form-group-half">
          <view class="form-label">末端空调冗余</view>
          <t-input value="{{form.endAirconRedundancy}}" placeholder="如 N+1" bind:change="onFieldChange" data-field="endAirconRedundancy" maxlength="10" />
        </view>
        <view class="form-group form-group-half">
          <view class="form-label">冷水机组数量</view>
          <view class="input-with-unit">
            <t-input value="{{form.chillerCount}}" placeholder="台数" type="number" bind:change="onFieldChange" data-field="chillerCount" />
            <text class="input-unit">{{unitFields.chillerCount}}</text>
          </view>
        </view>
      </view>
      <view class="form-group">
        <view class="form-label">PUE设计值</view>
        <t-input value="{{form.pueDesign}}" placeholder="如 1.3" type="digit" bind:change="onFieldChange" data-field="pueDesign" />
      </view>
    </view>
  </view>

  <!-- 五、承重与空间 -->
  <view class="section">
    <view class="section-label">五、承重与空间</view>
    <view class="card">
      <view class="form-row">
        <view class="form-group form-group-half">
          <view class="form-label">地板承重</view>
          <view class="input-with-unit">
            <t-input value="{{form.floorLoad}}" placeholder="要求>=1000" type="digit" bind:change="onFieldChange" data-field="floorLoad" />
            <text class="input-unit">{{unitFields.floorLoad}}</text>
          </view>
        </view>
        <view class="form-group form-group-half">
          <view class="form-label">架空地板高度</view>
          <view class="input-with-unit">
            <t-input value="{{form.raisedFloorHeight}}" placeholder="要求>=0.6" type="digit" bind:change="onFieldChange" data-field="raisedFloorHeight" />
            <text class="input-unit">{{unitFields.raisedFloorHeight}}</text>
          </view>
        </view>
      </view>
      <view class="form-row">
        <view class="form-group form-group-third">
          <view class="form-label">货梯宽度</view>
          <view class="input-with-unit">
            <t-input value="{{form.freightElevatorWidth}}" placeholder="米" type="digit" bind:change="onFieldChange" data-field="freightElevatorWidth" />
            <text class="input-unit">{{unitFields.freightElevatorWidth}}</text>
          </view>
        </view>
        <view class="form-group form-group-third">
          <view class="form-label">货梯高度</view>
          <view class="input-with-unit">
            <t-input value="{{form.freightElevatorHeight}}" placeholder="米" type="digit" bind:change="onFieldChange" data-field="freightElevatorHeight" />
            <text class="input-unit">{{unitFields.freightElevatorHeight}}</text>
          </view>
        </view>
        <view class="form-group form-group-third">
          <view class="form-label">货梯承重</view>
          <view class="input-with-unit">
            <t-input value="{{form.freightElevatorLoad}}" placeholder="要求>=2" type="digit" bind:change="onFieldChange" data-field="freightElevatorLoad" />
            <text class="input-unit">{{unitFields.freightElevatorLoad}}</text>
          </view>
        </view>
      </view>
      <view class="form-row">
        <view class="form-group form-group-half">
          <view class="form-label">主运输通道宽度</view>
          <view class="input-with-unit">
            <t-input value="{{form.transportCorridorWidth}}" placeholder="要求>=1.5" type="digit" bind:change="onFieldChange" data-field="transportCorridorWidth" />
            <text class="input-unit">{{unitFields.transportCorridorWidth}}</text>
          </view>
        </view>
        <view class="form-group form-group-half">
          <view class="form-label">卸货平台</view>
          <t-picker value="{{form.loadingDock}}" title="选择" options="{{pickerOptions.loadingDock}}" bind:confirm="onPickerConfirm" data-field="loadingDock" id="picker-loadingDock">
            <t-cell title="卸货平台" value="{{form.loadingDock || '请选择'}}" arrow bind:tap="onPickerTap" data-field="loadingDock" />
          </t-picker>
        </view>
      </view>
    </view>
  </view>

  <!-- 六、网络与互联 -->
  <view class="section">
    <view class="section-label">六、网络与互联</view>
    <view class="card">
      <view class="form-row">
        <view class="form-group form-group-half">
          <view class="form-label">网络进线路由</view>
          <view class="input-with-unit">
            <t-input value="{{form.networkRoutes}}" placeholder="路数" type="number" bind:change="onFieldChange" data-field="networkRoutes" />
            <text class="input-unit">{{unitFields.networkRoutes}}</text>
          </view>
        </view>
        <view class="form-group form-group-half">
          <view class="form-label">运营商数量</view>
          <view class="input-with-unit">
            <t-input value="{{form.ispCount}}" placeholder="家数" type="number" bind:change="onFieldChange" data-field="ispCount" />
            <text class="input-unit">{{unitFields.ispCount}}</text>
          </view>
        </view>
      </view>
      <view class="form-group">
        <view class="form-label">裸光纤资源</view>
        <t-picker value="{{form.darkFiber}}" title="选择" options="{{pickerOptions.darkFiber}}" bind:confirm="onPickerConfirm" data-field="darkFiber" id="picker-darkFiber">
          <t-cell title="裸光纤" value="{{form.darkFiber || '请选择'}}" arrow bind:tap="onPickerTap" data-field="darkFiber" />
        </t-picker>
      </view>
      <view class="form-row">
        <view class="form-group form-group-half">
          <view class="form-label">800G网络支持</view>
          <t-picker value="{{form.support800G}}" title="选择" options="{{pickerOptions.support800G}}" bind:confirm="onPickerConfirm" data-field="support800G" id="picker-support800G">
            <t-cell title="800G网络" value="{{form.support800G || '请选择'}}" arrow bind:tap="onPickerTap" data-field="support800G" />
          </t-picker>
        </view>
        <view class="form-group form-group-half">
          <view class="form-label">RoCE/IB支持</view>
          <t-picker value="{{form.supportRoCEIB}}" title="选择" options="{{pickerOptions.supportRoCEIB}}" bind:confirm="onPickerConfirm" data-field="supportRoCEIB" id="picker-supportRoCEIB">
            <t-cell title="RoCE/IB" value="{{form.supportRoCEIB || '请选择'}}" arrow bind:tap="onPickerTap" data-field="supportRoCEIB" />
          </t-picker>
        </view>
      </view>
    </view>
  </view>

  <!-- 七、交付时间 -->
  <view class="section">
    <view class="section-label">七、交付时间</view>
    <view class="card">
      <view class="form-row">
        <view class="form-group form-group-half">
          <view class="form-label">3个月内可交付</view>
          <view class="input-with-unit">
            <t-input value="{{form.delivery3Months}}" placeholder="MW" type="digit" bind:change="onFieldChange" data-field="delivery3Months" />
            <text class="input-unit">{{unitFields.delivery3Months}}</text>
          </view>
        </view>
        <view class="form-group form-group-half">
          <view class="form-label">6个月内可交付</view>
          <view class="input-with-unit">
            <t-input value="{{form.delivery6Months}}" placeholder="MW" type="digit" bind:change="onFieldChange" data-field="delivery6Months" />
            <text class="input-unit">{{unitFields.delivery6Months}}</text>
          </view>
        </view>
      </view>
      <view class="form-row">
        <view class="form-group form-group-half">
          <view class="form-label">现有液冷机柜功率</view>
          <view class="input-with-unit">
            <t-input value="{{form.existingLiquidPower}}" placeholder="kW/柜" type="digit" bind:change="onFieldChange" data-field="existingLiquidPower" />
            <text class="input-unit">{{unitFields.existingLiquidPower}}</text>
          </view>
        </view>
        <view class="form-group form-group-half">
          <view class="form-label">现有液冷机柜数量</view>
          <view class="input-with-unit">
            <t-input value="{{form.existingLiquidCount}}" placeholder="个" type="number" bind:change="onFieldChange" data-field="existingLiquidCount" />
            <text class="input-unit">{{unitFields.existingLiquidCount}}</text>
          </view>
        </view>
      </view>
      <view class="form-row">
        <view class="form-group form-group-half">
          <view class="form-label">电力改造周期</view>
          <view class="input-with-unit">
            <t-input value="{{form.powerRetrofitPeriod}}" placeholder="月" type="number" bind:change="onFieldChange" data-field="powerRetrofitPeriod" />
            <text class="input-unit">{{unitFields.powerRetrofitPeriod}}</text>
          </view>
        </view>
        <view class="form-group form-group-half">
          <view class="form-label">制冷改造周期</view>
          <view class="input-with-unit">
            <t-input value="{{form.coolingRetrofitPeriod}}" placeholder="月" type="number" bind:change="onFieldChange" data-field="coolingRetrofitPeriod" />
            <text class="input-unit">{{unitFields.coolingRetrofitPeriod}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 八、配套服务 -->
  <view class="section">
    <view class="section-label">八、配套服务</view>
    <view class="card">
      <view class="form-row">
        <view class="form-group form-group-half">
          <view class="form-label">办公区工位数</view>
          <view class="input-with-unit">
            <t-input value="{{form.officeSeats}}" placeholder="工位数" type="number" bind:change="onFieldChange" data-field="officeSeats" />
            <text class="input-unit">{{unitFields.officeSeats}}</text>
          </view>
        </view>
        <view class="form-group form-group-half">
          <view class="form-label">库房面积</view>
          <view class="input-with-unit">
            <t-input value="{{form.storageArea}}" placeholder="㎡" type="digit" bind:change="onFieldChange" data-field="storageArea" />
            <text class="input-unit">{{unitFields.storageArea}}</text>
          </view>
        </view>
      </view>
      <view class="form-row">
        <view class="form-group form-group-half">
          <view class="form-label">7x24运维值守</view>
          <t-picker value="{{form.ops24x7}}" title="选择" options="{{pickerOptions.ops24x7}}" bind:confirm="onPickerConfirm" data-field="ops24x7" id="picker-ops24x7">
            <t-cell title="运维值守" value="{{form.ops24x7 || '请选择'}}" arrow bind:tap="onPickerTap" data-field="ops24x7" />
          </t-picker>
        </view>
        <view class="form-group form-group-half">
          <view class="form-label">故障响应时间</view>
          <view class="input-with-unit">
            <t-input value="{{form.faultResponseTime}}" placeholder="小时" type="digit" bind:change="onFieldChange" data-field="faultResponseTime" />
            <text class="input-unit">{{unitFields.faultResponseTime}}</text>
          </view>
        </view>
      </view>
      <view class="form-group">
        <view class="form-label">液冷维护能力</view>
        <t-picker value="{{form.liquidCoolMaintenance}}" title="选择" options="{{pickerOptions.liquidCoolMaintenance}}" bind:confirm="onPickerConfirm" data-field="liquidCoolMaintenance" id="picker-liquidCoolMaintenance">
          <t-cell title="液冷维护" value="{{form.liquidCoolMaintenance || '请选择'}}" arrow bind:tap="onPickerTap" data-field="liquidCoolMaintenance" />
        </t-picker>
      </view>
    </view>
  </view>

  <!-- 九、成本与报价 -->
  <view class="section">
    <view class="section-label">九、成本与报价</view>
    <view class="card">
      <view class="form-group">
        <view class="form-label">电费计费模式</view>
        <t-picker value="{{form.electricityBilling}}" title="选择" options="{{pickerOptions.electricityBilling}}" bind:confirm="onPickerConfirm" data-field="electricityBilling" id="picker-electricityBilling">
          <t-cell title="电费模式" value="{{form.electricityBilling || '请选择'}}" arrow bind:tap="onPickerTap" data-field="electricityBilling" />
        </t-picker>
      </view>
      <view class="form-row">
        <view class="form-group form-group-half">
          <view class="form-label">一次性接入费</view>
          <view class="input-with-unit">
            <t-input value="{{form.oneTimeFee}}" placeholder="金额" type="digit" bind:change="onFieldChange" data-field="oneTimeFee" />
            <text class="input-unit">{{unitFields.oneTimeFee}}</text>
          </view>
        </view>
        <view class="form-group form-group-half">
          <view class="form-label">液冷服务费</view>
          <view class="input-with-unit">
            <t-input value="{{form.liquidCoolServiceFee}}" placeholder="费用" type="digit" bind:change="onFieldChange" data-field="liquidCoolServiceFee" />
            <text class="input-unit">{{unitFields.liquidCoolServiceFee}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 拜访信息 & 备注 & 照片 -->
  <view class="section">
    <view class="section-label">拜访信息与备注</view>
    <view class="card">
      <view class="form-group">
        <view class="form-label">拜访日期</view>
        <view class="date-display">{{form.visitDate || getToday()}}</view>
      </view>
      <view class="form-row">
        <view class="form-group form-group-half">
          <view class="form-label">联系人</view>
          <t-input value="{{form.contactPerson}}" placeholder="姓名" bind:change="onFieldChange" data-field="contactPerson" maxlength="50" />
        </view>
        <view class="form-group form-group-half">
          <view class="form-label">联系方式</view>
          <t-input value="{{form.contactInfo}}" placeholder="电话/邮箱" bind:change="onFieldChange" data-field="contactInfo" maxlength="100" />
        </view>
      </view>
      <view class="form-group">
        <view class="form-label">备注</view>
        <t-textarea value="{{form.notes}}" placeholder="现场观察、特殊说明..." bind:change="onFieldChange" data-field="notes" maxlength="500" autosize />
      </view>
      <view class="form-group">
        <view class="form-label">现场照片（最多6张）</view>
        <t-image-upload
          value="{{form.photos}}"
          max="{{6}}"
          sizeLimit="{{5 * 1024 * 1024}}"
          gridConfig="{{imageGridConfig}}"
          bind:add="onPhotoAdd"
          bind:remove="onPhotoRemove"
        />
      </view>
    </view>
  </view>

  <!-- 底部提交 -->
  <view class="submit-bar">
    <t-button theme="primary" block bindtap="handleSubmit" loading="{{submitting}}">
      {{mode === 'edit' ? '保存修改' : '提交采集记录'}}
    </t-button>
  </view>

  <watermark />
</view>
