<!--pages/form/basic.wxml - 添加机房（重设计：第一屏精简 + 展开区分组折叠）-->
<view class="page-form">

  <!-- ==================== 第一屏：快速信息（9-10字段，外勤5分钟可完成）==================== -->
  <view class="section section-quick">
    <view class="section-header">
      <t-icon name="info-circle" size="32rpx" color="#1E3A5F" />
      <text class="section-title">快速信息</text>
      <text class="section-hint">（外勤必填 · 优先录入）</text>
    </view>
    <view class="card card-quick">

      <!-- 机房名称（必填，单行）-->
      <view class="field-row">
        <view class="field-label">
          <text class="required-star">*</text><text>机房名称</text>
        </view>
        <t-input
          value="{{form.name}}"
          placeholder="如：Equinix SG3、新加坡SG1"
          bind:change="onFieldChange"
          data-field="name"
          maxlength="100"
          class="field-input"
        />
      </view>

      <!-- 所在地区（国家-省/州-城市 三列联动，必填）-->
      <view class="field-row">
        <view class="field-label">
          <text class="required-star">*</text><text>所在地区</text>
        </view>
        <t-picker
          value="{{[form.country, form.province, form.city]}}"
          bind:confirm="onRegionPickerConfirm"
          class="field-picker"
        >
          <t-picker-item options="{{regionOptions}}" />
          <t-picker-item options="{{provinceOptions}}" />
          <t-picker-item options="{{cityOptions}}" />
          <t-cell title="" value="{{regionLabel || '请选择地区'}}" arrow slot="trigger" />
        </t-picker>
      </view>

      <!-- 园区/街道（选填，手动输入）-->
      <view class="field-row">
        <view class="field-label"><text>园区/街道</text></view>
        <t-input
          value="{{form.zone}}"
          placeholder="选填"
          bind:change="onFieldChange"
          data-field="zone"
          maxlength="50"
          class="field-input"
        />
      </view>

      <!-- 可用电力（必填）-->
      <view class="field-row">
        <view class="field-label">
          <text class="required-star">*</text><text>可用电力（MW）</text>
        </view>
        <view class="input-wrap">
          <t-input
            value="{{form.availablePower}}"
            placeholder="如 8.0"
            type="digit"
            bind:change="onFieldChange"
            data-field="availablePower"
            class="field-input-digit"
          />
          <text class="unit-suffix">MW</text>
        </view>
      </view>

      <!-- 制冷方式（必填）-->
      <view class="field-row">
        <view class="field-label">
          <text class="required-star">*</text><text>制冷方式</text>
        </view>
        <t-picker
          value="{{form.mainCoolingType}}"
          columns="{{[{label: '风冷', value: '风冷'}, {label: '水冷', value: '水冷'}, {label: '液冷', value: '液冷'}, {label: '混合', value: '混合'}]}}"
          bind:change="onSinglePickerChange"
          data-field="mainCoolingType"
          class="field-picker"
        >
          <t-cell title="" value="{{form.mainCoolingType || '请选择制冷方式'}}" arrow />
        </t-picker>
      </view>

      <!-- 是否可扩容（必填）-->
      <view class="field-row">
        <view class="field-label">
          <text class="required-star">*</text><text>是否可扩容</text>
        </view>
        <t-picker
          value="{{form.expandable}}"
          columns="{{[{label: '可扩容', value: '可扩容'}, {label: '不可扩容', value: '不可扩容'}]}}"
          bind:change="onSinglePickerChange"
          data-field="expandable"
          class="field-picker"
        >
          <t-cell title="" value="{{form.expandable || '请选择'}}" arrow />
        </t-picker>
      </view>

      <!-- PUE设计值（选填）-->
      <view class="field-row">
        <view class="field-label"><text>PUE设计值</text></view>
        <view class="input-wrap">
          <t-input
            value="{{form.pueDesign}}"
            placeholder="如 1.40"
            type="digit"
            bind:change="onFieldChange"
            data-field="pueDesign"
            class="field-input-digit"
          />
          <text class="unit-suffix"></text>
        </view>
      </view>

      <!-- 预计交付时间（选填，YYYY-MM）-->
      <view class="field-row">
        <view class="field-label"><text>预计交付时间</text></view>
        <t-date-picker-year-month
          value="{{form.expectedDelivery}}"
          bind:change="onDeliveryDateChange"
          class="date-picker-wrap"
        >
          <t-cell title="" value="{{form.expectedDelivery || '请选择年月'}}" arrow />
        </t-date-picker-year-month>
      </view>

      <!-- 拜访日期（选填，YYYY-MM-DD）-->
      <view class="field-row">
        <view class="field-label"><text>拜访日期</text></view>
        <t-date-picker
          value="{{form.visitDate}}"
          format="YYYY-MM-DD"
          bind:change="onVisitDateChange"
          class="date-picker-wrap"
        >
          <t-cell title="" value="{{form.visitDate || '请选择日期'}}" arrow />
        </t-date-picker>
      </view>

      <!-- 联系人（选填）-->
      <view class="field-row">
        <view class="field-label"><text>联系人</text></view>
        <t-input
          value="{{form.contactPerson}}"
          placeholder="姓名"
          bind:change="onFieldChange"
          data-field="contactPerson"
          class="field-input"
        />
      </view>

      <!-- 联系电话（选填）-->
      <view class="field-row">
        <view class="field-label"><text>联系电话</text></view>
        <t-input
          value="{{form.contactInfo}}"
          placeholder="手机号"
          type="digit"
          maxlength="20"
          bind:change="onFieldChange"
          data-field="contactInfo"
          class="field-input"
        />
      </view>

    </view>
  </view>

  <!-- ==================== 展开/收起按钮 ==================== -->
  <view class="expand-toggle" bindtap="toggleExpand">
    <t-icon name="{{expanded ? 'chevron-up' : 'chevron-down'}}" size="32rpx" color="#1E3A5F" />
    <text>{{expanded ? '收起全部字段' : '展开全部字段'}}</text>
  </view>

  <!-- ==================== 展开区：按模块折叠分组 ==================== -->
  <block wx:if="{{expanded}}">

    <!-- 一、机柜资源 -->
    <view class="section">
      <view class="collapse-header" bindtap="toggleSection" data-section="cabinets">
        <t-icon name="{{openSections.cabinets ? 'chevron-up' : 'chevron-down'}}" size="32rpx" color="#1E3A5F" />
        <text class="collapse-title">一、机柜资源</text>
        <text class="collapse-badge">{{sectionFilledCount.cabinets || 0}}/5</text>
      </view>
      <view class="card {{openSections.cabinets ? '' : 'collapsed'}}">
        <view class="field-row">
          <view class="field-label"><text>总机柜数量（个）</text></view>
          <view class="input-wrap">
            <t-input value="{{form.totalCabinets}}" type="number" bind:change="onFieldChange" data-field="totalCabinets" class="field-input-digit" />
            <text class="unit-suffix">个</text>
          </view>
        </view>
        <view class="field-row">
          <view class="field-label"><text>当前可提供机柜数</text></view>
          <view class="input-wrap">
            <t-input value="{{form.availableCabinets}}" type="number" bind:change="onFieldChange" data-field="availableCabinets" class="field-input-digit" />
            <text class="unit-suffix">个</text>
          </view>
        </view>
        <view class="field-row">
          <view class="field-label"><text>机柜最高功率（kW/柜）</text></view>
          <view class="input-wrap">
            <t-input value="{{form.maxCabinetPower}}" type="digit" bind:change="onFieldChange" data-field="maxCabinetPower" class="field-input-digit" />
            <text class="unit-suffix">kW/柜</text>
          </view>
        </view>
        <view class="field-row">
          <view class="field-label"><text>是否支持连续布置</text></view>
          <t-picker value="{{form.continuousCabinet}}" columns="{{[{label: '是', value: '是'}, {label: '否', value: '否'}]}}" bind:change="onSinglePickerChange" data-field="continuousCabinet" class="field-picker">
            <t-cell title="" value="{{form.continuousCabinet || '请选择'}}" arrow />
          </t-picker>
        </view>
        <view class="field-row">
          <view class="field-label"><text>是否支持物理隔离</text></view>
          <t-picker value="{{form.physicalIsolation}}" columns="{{[{label: '是', value: '是'}, {label: '否', value: '否'}, {label: '改造可行', value: '改造可行'}]}}" bind:change="onSinglePickerChange" data-field="physicalIsolation" class="field-picker">
            <t-cell title="" value="{{form.physicalIsolation || '请选择'}}" arrow />
          </t-picker>
        </view>
      </view>
    </view>

    <!-- 二、电力系统 -->
    <view class="section">
      <view class="collapse-header" bindtap="toggleSection" data-section="power">
        <t-icon name="{{openSections.power ? 'chevron-up' : 'chevron-down'}}" size="32rpx" color="#1E3A5F" />
        <text class="collapse-title">二、电力系统</text>
        <text class="collapse-badge">{{sectionFilledCount.power || 0}}/7</text>
      </view>
      <view class="card {{openSections.power ? '' : 'collapsed'}}">
        <view class="field-row">
          <view class="field-label"><text>市电总容量（kVA）</text></view>
          <view class="input-wrap">
            <t-input value="{{form.mainsCapacity}}" type="digit" bind:change="onFieldChange" data-field="mainsCapacity" class="field-input-digit" />
            <text class="unit-suffix">kVA</text>
          </view>
        </view>
        <view class="field-row">
          <view class="field-label"><text>可扩容电力上限（MW）</text></view>
          <view class="input-wrap">
            <t-input value="{{form.expandablePower}}" type="digit" bind:change="onFieldChange" data-field="expandablePower" class="field-input-digit" />
            <text class="unit-suffix">MW</text>
          </view>
        </view>
        <view class="field-row">
          <view class="field-label"><text>变压器配置</text></view>
          <t-picker value="{{form.transformerConfig}}" columns="{{[{label: '2N', value: '2N'}, {label: 'N+1', value: 'N+1'}, {label: 'N', value: 'N'}]}}" bind:change="onSinglePickerChange" data-field="transformerConfig" class="field-picker">
            <t-cell title="" value="{{form.transformerConfig || '请选择'}}" arrow />
          </t-picker>
        </view>
        <view class="field-row">
          <view class="field-label"><text>柴发冗余等级</text></view>
          <t-input value="{{form.generatorRedundancy}}" placeholder="如 N+1" bind:change="onFieldChange" data-field="generatorRedundancy" class="field-input" />
        </view>
        <view class="field-row">
          <view class="field-label"><text>UPS配置</text></view>
          <t-picker value="{{form.upsConfig}}" columns="{{[{label: '2N', value: '2N'}, {label: '分布式', value: '分布式'}, {label: '后备', value: '后备'}]}}" bind:change="onSinglePickerChange" data-field="upsConfig" class="field-picker">
            <t-cell title="" value="{{form.upsConfig || '请选择'}}" arrow />
          </t-picker>
        </view>
        <view class="field-row">
          <view class="field-label"><text>电力SLA</text></view>
          <t-picker value="{{form.powerSLA}}" columns="{{[{label: '99.99%', value: '99.99%'}, {label: '99.999%', value: '99.999%'}]}}" bind:change="onSinglePickerChange" data-field="powerSLA" class="field-picker">
            <t-cell title="" value="{{form.powerSLA || '请选择'}}" arrow />
          </t-picker>
        </view>
        <view class="field-row">
          <view class="field-label"><text>是否有机电</text></view>
          <t-picker value="{{form.hasGenerator}}" columns="{{[{label: '是', value: '是'}, {label: '否', value: '否'}]}}" bind:change="onSinglePickerChange" data-field="hasGenerator" class="field-picker">
            <t-cell title="" value="{{form.hasGenerator || '请选择'}}" arrow />
          </t-picker>
        </view>
      </view>
    </view>

    <!-- 三、制冷系统 -->
    <view class="section">
      <view class="collapse-header" bindtap="toggleSection" data-section="cooling">
        <t-icon name="{{openSections.cooling ? 'chevron-up' : 'chevron-down'}}" size="32rpx" color="#1E3A5F" />
        <text class="collapse-title">三、制冷系统</text>
        <text class="collapse-badge">{{sectionFilledCount.cooling || 0}}/5</text>
      </view>
      <view class="card {{openSections.cooling ? '' : 'collapsed'}}">
        <view class="field-row">
          <view class="field-label"><text>冷板液冷</text></view>
          <t-picker value="{{form.liquidCooling}}" columns="{{[{label: '标配', value: '标配'}, {label: '可改造', value: '可改造'}, {label: '无', value: '无'}]}}" bind:change="onSinglePickerChange" data-field="liquidCooling" class="field-picker">
            <t-cell title="" value="{{form.liquidCooling || '请选择'}}" arrow />
          </t-picker>
        </view>
        <view class="field-row">
          <view class="field-label"><text>液冷改造周期（月）</text></view>
          <view class="input-wrap">
            <t-input value="{{form.liquidCoolingPeriod}}" type="digit" bind:change="onFieldChange" data-field="liquidCoolingPeriod" class="field-input-digit" />
            <text class="unit-suffix">月</text>
          </view>
        </view>
        <view class="field-row">
          <view class="field-label"><text>是否配备CDU</text></view>
          <t-picker value="{{form.cduEquipped}}" columns="{{[{label: '是', value: '是'}, {label: '否', value: '否'}]}}" bind:change="onSinglePickerChange" data-field="cduEquipped" class="field-picker">
            <t-cell title="" value="{{form.cduEquipped || '请选择'}}" arrow />
          </t-picker>
        </view>
        <view class="field-row">
          <view class="field-label"><text>冷冻水供水温度（℃）</text></view>
          <view class="input-wrap">
            <t-input value="{{form.chilledWaterSupply}}" type="digit" bind:change="onFieldChange" data-field="chilledWaterSupply" class="field-input-digit" />
            <text class="unit-suffix">℃</text>
          </view>
        </view>
        <view class="field-row">
          <view class="field-label"><text>冷水机组数量（台）</text></view>
          <view class="input-wrap">
            <t-input value="{{form.chillerCount}}" type="number" bind:change="onFieldChange" data-field="chillerCount" class="field-input-digit" />
            <text class="unit-suffix">台</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 四、交付与扩容 -->
    <view class="section">
      <view class="collapse-header" bindtap="toggleSection" data-section="delivery">
        <t-icon name="{{openSections.delivery ? 'chevron-up' : 'chevron-down'}}" size="32rpx" color="#1E3A5F" />
        <text class="collapse-title">四、交付与扩容</text>
        <text class="collapse-badge">{{sectionFilledCount.delivery || 0}}/6</text>
      </view>
      <view class="card {{openSections.delivery ? '' : 'collapsed'}}">
        <view class="field-row">
          <view class="field-label"><text>3个月可交付电力（MW）</text></view>
          <view class="input-wrap">
            <t-input value="{{form.delivery3m}}" type="digit" bind:change="onFieldChange" data-field="delivery3m" class="field-input-digit" />
            <text class="unit-suffix">MW</text>
          </view>
        </view>
        <view class="field-row">
          <view class="field-label"><text>6个月可交付电力（MW）</text></view>
          <view class="input-wrap">
            <t-input value="{{form.delivery6m}}" type="digit" bind:change="onFieldChange" data-field="delivery6m" class="field-input-digit" />
            <text class="unit-suffix">MW</text>
          </view>
        </view>
        <view class="field-row">
          <view class="field-label"><text>电力改造周期（月）</text></view>
          <view class="input-wrap">
            <t-input value="{{form.powerUpgradeMonths}}" type="digit" bind:change="onFieldChange" data-field="powerUpgradeMonths" class="field-input-digit" />
            <text class="unit-suffix">月</text>
          </view>
        </view>
        <view class="field-row">
          <view class="field-label"><text>制冷改造周期（月）</text></view>
          <view class="input-wrap">
            <t-input value="{{form.coolingUpgradeMonths}}" type="digit" bind:change="onFieldChange" data-field="coolingUpgradeMonths" class="field-input-digit" />
            <text class="unit-suffix">月</text>
          </view>
        </view>
        <view class="field-row">
          <view class="field-label"><text>液冷功率（kW/柜）</text></view>
          <view class="input-wrap">
            <t-input value="{{form.liquidCabinetPower}}" type="digit" bind:change="onFieldChange" data-field="liquidCabinetPower" class="field-input-digit" />
            <text class="unit-suffix">kW/柜</text>
          </view>
        </view>
        <view class="field-row">
          <view class="field-label"><text>液冷机柜数（个）</text></view>
          <view class="input-wrap">
            <t-input value="{{form.liquidCabinetCount}}" type="number" bind:change="onFieldChange" data-field="liquidCabinetCount" class="field-input-digit" />
            <text class="unit-suffix">个</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 五、网络与互联 -->
    <view class="section">
      <view class="collapse-header" bindtap="toggleSection" data-section="network">
        <t-icon name="{{openSections.network ? 'chevron-up' : 'chevron-down'}}" size="32rpx" color="#1E3A5F" />
        <text class="collapse-title">五、网络与互联</text>
        <text class="collapse-badge">{{sectionFilledCount.network || 0}}/4</text>
      </view>
      <view class="card {{openSections.network ? '' : 'collapsed'}}">
        <view class="field-row">
          <view class="field-label"><text>进线路由（路）</text></view>
          <view class="input-wrap">
            <t-input value="{{form.networkRoutes}}" type="number" bind:change="onFieldChange" data-field="networkRoutes" class="field-input-digit" />
            <text class="unit-suffix">路</text>
          </view>
        </view>
        <view class="field-row">
          <view class="field-label"><text>运营商数量（家）</text></view>
          <view class="input-wrap">
            <t-input value="{{form.operatorCount}}" type="number" bind:change="onFieldChange" data-field="operatorCount" class="field-input-digit" />
            <text class="unit-suffix">家</text>
          </view>
        </view>
        <view class="field-row">
          <view class="field-label"><text>是否支持裸光纤</text></view>
          <t-picker value="{{form.bareFiberSupport}}" columns="{{[{label: '支持', value: '支持'}, {label: '不支持', value: '不支持'}]}}" bind:change="onSinglePickerChange" data-field="bareFiberSupport" class="field-picker">
            <t-cell title="" value="{{form.bareFiberSupport || '请选择'}}" arrow />
          </t-picker>
        </view>
        <view class="field-row">
          <view class="field-label"><text>是否支持800G网络</text></view>
          <t-picker value="{{form.support800g}}" columns="{{[{label: '支持', value: '支持'}, {label: '不支持', value: '不支持'}, {label: '规划中', value: '规划中'}]}}" bind:change="onSinglePickerChange" data-field="support800g" class="field-picker">
            <t-cell title="" value="{{form.support800g || '请选择'}}" arrow />
          </t-picker>
        </view>
      </view>
    </view>

    <!-- 六、配套服务 -->
    <view class="section">
      <view class="collapse-header" bindtap="toggleSection" data-section="service">
        <t-icon name="{{openSections.service ? 'chevron-up' : 'chevron-down'}}" size="32rpx" color="#1E3A5F" />
        <text class="collapse-title">六、配套服务</text>
        <text class="collapse-badge">{{sectionFilledCount.service || 0}}/4</text>
      </view>
      <view class="card {{openSections.service ? '' : 'collapsed'}}">
        <view class="field-row">
          <view class="field-label"><text>工位数</text></view>
          <view class="input-wrap">
            <t-input value="{{form.officeSeats}}" type="number" bind:change="onFieldChange" data-field="officeSeats" class="field-input-digit" />
            <text class="unit-suffix">工位</text>
          </view>
        </view>
        <view class="field-row">
          <view class="field-label"><text>库房面积（㎡）</text></view>
          <view class="input-wrap">
            <t-input value="{{form.storageArea}}" type="digit" bind:change="onFieldChange" data-field="storageArea" class="field-input-digit" />
            <text class="unit-suffix">㎡</text>
          </view>
        </view>
        <view class="field-row">
          <view class="field-label"><text>7×24运维</text></view>
          <t-picker value="{{form.ops247}}" columns="{{[{label: '有（独立）', value: '有（独立）'}, {label: '有（共享）', value: '有（共享）'}, {label: '无', value: '无'}]}}" bind:change="onSinglePickerChange" data-field="ops247" class="field-picker">
            <t-cell title="" value="{{form.ops247 || '请选择'}}" arrow />
          </t-picker>
        </view>
        <view class="field-row">
          <view class="field-label"><text>故障响应时间（小时）</text></view>
          <view class="input-wrap">
            <t-input value="{{form.faultResponseHours}}" type="digit" bind:change="onFieldChange" data-field="faultResponseHours" class="field-input-digit" />
            <text class="unit-suffix">小时</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 七、成本与报价 -->
    <view class="section">
      <view class="collapse-header" bindtap="toggleSection" data-section="cost">
        <t-icon name="{{openSections.cost ? 'chevron-up' : 'chevron-down'}}" size="32rpx" color="#1E3A5F" />
        <text class="collapse-title">七、成本与报价</text>
        <text class="collapse-badge">{{sectionFilledCount.cost || 0}}/3</text>
      </view>
      <view class="card {{openSections.cost ? '' : 'collapsed'}}">
        <view class="field-row">
          <view class="field-label"><text>电费模式</text></view>
          <t-picker value="{{form.billingMode}}" columns="{{[{label: '包干', value: '包干'}, {label: '按量', value: '按量'}, {label: '混合', value: '混合'}]}}" bind:change="onSinglePickerChange" data-field="billingMode" class="field-picker">
            <t-cell title="" value="{{form.billingMode || '请选择'}}" arrow />
          </t-picker>
        </view>
        <view class="field-row">
          <view class="field-label"><text>接入费（元）</text></view>
          <view class="input-wrap">
            <t-input value="{{form.oneTimeFee}}" type="digit" placeholder="一次性费用" bind:change="onFieldChange" data-field="oneTimeFee" class="field-input-digit" />
            <text class="unit-suffix">元</text>
          </view>
        </view>
        <view class="field-row">
          <view class="field-label"><text>机柜单价（元/柜/月）</text></view>
          <view class="input-wrap">
            <t-input value="{{form.cabinetPrice}}" type="digit" bind:change="onFieldChange" data-field="cabinetPrice" class="field-input-digit" />
            <text class="unit-suffix">元/柜/月</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 八、基础信息 -->
    <view class="section">
      <view class="collapse-header" bindtap="toggleSection" data-section="basic">
        <t-icon name="{{openSections.basic ? 'chevron-up' : 'chevron-down'}}" size="32rpx" color="#1E3A5F" />
        <text class="collapse-title">八、基础信息</text>
        <text class="collapse-badge">{{sectionFilledCount.basic || 0}}/8</text>
      </view>
      <view class="card {{openSections.basic ? '' : 'collapsed'}}">
        <view class="field-row">
          <view class="field-label"><text>机房编码</text></view>
          <t-input value="{{form.code}}" placeholder="如 IDC-2026-001" bind:change="onFieldChange" data-field="code" class="field-input" />
        </view>
        <view class="field-row">
          <view class="field-label"><text>产权归属</text></view>
          <t-picker value="{{form.ownership}}" columns="{{[{label: '自有', value: '自有'}, {label: '租赁', value: '租赁'}]}}" bind:change="onSinglePickerChange" data-field="ownership" class="field-picker">
            <t-cell title="" value="{{form.ownership || '请选择'}}" arrow />
          </t-picker>
        </view>
        <view class="field-row">
          <view class="field-label"><text>信息来源</text></view>
          <t-input value="{{form.source}}" placeholder="如 客户主动联系" bind:change="onFieldChange" data-field="source" class="field-input" />
        </view>
        <view class="field-row">
          <view class="field-label"><text>对接同事</text></view>
          <t-input value="{{form.liaison}}" placeholder="负责跟进的同事" bind:change="onFieldChange" data-field="liaison" class="field-input" />
        </view>
        <view class="field-row">
          <view class="field-label"><text>KYC状态</text></view>
          <t-picker value="{{form.kycStatus}}" columns="{{[{label: '未开始', value: '未开始'}, {label: '进行中', value: '进行中'}, {label: '待补充材料', value: '待补充材料'}, {label: '已完成', value: '已完成'}, {label: '已驳回', value: '已驳回'}, {label: '不需要', value: '不需要'}]}}" bind:change="onSinglePickerChange" data-field="kycStatus" class="field-picker">
            <t-cell title="" value="{{form.kycStatus || '请选择'}}" arrow />
          </t-picker>
        </view>
        <view class="field-row">
          <view class="field-label"><text>KYC卡点/备注</text></view>
          <t-input value="{{form.kycRemark}}" placeholder="当前卡点及解决办法" bind:change="onFieldChange" data-field="kycRemark" class="field-input" />
        </view>
        <view class="field-row">
          <view class="field-label"><text>机房状态</text></view>
          <t-picker value="{{form.status}}" columns="{{[{label: '新增', value: '新增'}, {label: '已收录', value: '已收录'}, {label: '待核实', value: '待核实'}, {label: '已驳回', value: '已驳回'}]}}" bind:change="onSinglePickerChange" data-field="status" class="field-picker">
            <t-cell title="" value="{{form.status || '请选择'}}" arrow />
          </t-picker>
        </view>
        <view class="field-row">
          <view class="field-label"><text>备注</text></view>
          <t-textarea value="{{form.notes}}" placeholder="现场观察、特殊说明..." bind:change="onFieldChange" data-field="notes" maxlength="1000" autosize class="field-textarea" />
        </view>
      </view>
    </view>

    <!-- 九、现场照片 -->
    <view class="section">
      <view class="collapse-header" bindtap="toggleSection" data-section="photos">
        <t-icon name="{{openSections.photos ? 'chevron-up' : 'chevron-down'}}" size="32rpx" color="#1E3A5F" />
        <text class="collapse-title">九、现场照片</text>
        <text class="collapse-badge">{{form.photos.length || 0}}/6</text>
      </view>
      <view class="card {{openSections.photos ? '' : 'collapsed'}}">
        <view class="photo-section">
          <t-image-upload
            value="{{form.photos}}"
            max="{{6}}"
            sizeLimit="{{5 * 1024 * 1024}}"
            gridConfig="{{imageGridConfig}}"
            bind:add="onPhotoAdd"
            bind:remove="onPhotoRemove"
          />
        </view>
      </view>
    </view>

  </block>

  <!-- ==================== 底部提交栏 ==================== -->
  <view class="submit-bar">
    <t-button theme="primary" block bindtap="handleSubmit" loading="{{submitting}}">
      {{mode === 'edit' ? '保存修改' : '添加机房'}}
    </t-button>
  </view>

  <watermark />
</view>
