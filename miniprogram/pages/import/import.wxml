<!--pages/import/import.wxml-->
<view class="page-import">
  <view class="import-header">
    <view class="header-desc">从 Excel 文件批量导入机房信息，导入的数据将连同导入人姓名一同记录</view>
  </view>

  <!-- 步骤一：导出模板 -->
  <view class="section">
    <view class="section-label">步骤一：获取填写模板</view>
    <view class="card">
      <view class="step-desc">先导出空白模板 Excel，发送给机房服务商填写后收回</view>
      <t-button theme="primary" variant="outline" icon="download" bindtap="handleExportTemplate" loading="{{exportingTemplate}}">
        导出空白模板
      </t-button>
    </view>
  </view>

  <!-- 步骤二：选择文件导入 -->
  <view class="section">
    <view class="section-label">步骤二：导入填写好的文件</view>
    <view class="card">
      <view class="step-desc">选择机房服务商填写好的 Excel 文件</view>
      <view class="file-picker" bindtap="handleChooseFile">
        <view wx:if="{{!fileName}}" class="file-picker-placeholder">
          <t-icon name="upload" size="48rpx" color="#94A3B8" />
          <text>点击选择 Excel 文件</text>
        </view>
        <view wx:else class="file-picker-selected">
          <t-icon name="file-excel" size="48rpx" color="#00B42A" />
          <view class="file-info">
            <text class="file-name">{{fileName}}</text>
            <text class="file-size">{{fileSize}}</text>
          </view>
          <t-icon name="close-circle-filled" size="40rpx" color="#94A3B8" bindtap="handleRemoveFile" data-stop="true" />
        </view>
      </view>
      <t-button
        wx:if="{{fileId}}"
        theme="primary"
        block
        icon="check-circle"
        bindtap="handleImport"
        loading="{{importing}}"
        disabled="{{importing}}"
      >
        开始导入
      </t-button>
    </view>
  </view>

  <!-- 导入结果 -->
  <view wx:if="{{importResult}}" class="section">
    <view class="section-label">导入结果</view>
    <view class="card import-result">
      <view class="result-summary">
        <view class="result-item result-success">
          <text class="result-num">{{importResult.created}}</text>
          <text class="result-label">新增</text>
        </view>
        <view class="result-item result-update">
          <text class="result-num">{{importResult.updated}}</text>
          <text class="result-label">更新</text>
        </view>
        <view class="result-item result-fail" wx:if="{{importResult.errors && importResult.errors.length > 0}}">
          <text class="result-num">{{importResult.errors.length}}</text>
          <text class="result-label">失败</text>
        </view>
      </view>
      <view wx:if="{{importResult.errors && importResult.errors.length > 0}}" class="result-errors">
        <view class="error-title">失败明细：</view>
        <view wx:for="{{importResult.errors}}" wx:key="index" class="error-item">
          <text>第{{item.row}}行：{{item.message}}</text>
        </view>
      </view>
      <view class="result-meta">
        <text>导入人：{{importResult.importedByName}}</text>
        <text class="meta-divider">|</text>
        <text>{{importResult.importedAt}}</text>
      </view>
    </view>
  </view>

  <!-- 使用须知 -->
  <view class="section">
    <view class="section-label">使用须知</view>
    <view class="card">
      <view class="notice-list">
        <view class="notice-item">
          <t-icon name="info-circle" size="32rpx" color="#E8843C" />
          <text>Excel 文件必须使用本系统导出的模板格式</text>
        </view>
        <view class="notice-item">
          <t-icon name="info-circle" size="32rpx" color="#E8843C" />
          <text>同名的机房记录将被更新，其余视为新增</text>
        </view>
        <view class="notice-item">
          <t-icon name="info-circle" size="32rpx" color="#E8843C" />
          <text>导入数据将自动记录导入人姓名和导入时间</text>
        </view>
        <view class="notice-item">
          <t-icon name="info-circle" size="32rpx" color="#E8843C" />
          <text>机房信息为保密数据，请妥善保管文件</text>
        </view>
      </view>
    </view>
  </view>

  <watermark />
</view>
