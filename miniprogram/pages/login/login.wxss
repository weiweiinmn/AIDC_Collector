/* pages/login/login.wxss */
.page-login {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1E3A5F 0%, #0D1F3C 100%);
  padding: 60rpx 48rpx;
  box-sizing: border-box;
}

.login-container {
  width: 100%;
  max-width: 600rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* Logo */
.login-logo {
  text-align: center;
  margin-bottom: 60rpx;
}

.logo-icon {
  width: 160rpx;
  height: 160rpx;
  border-radius: 32rpx;
  background: rgba(232, 132, 60, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 32rpx;
}

.logo-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #FFFFFF;
  letter-spacing: 4rpx;
}

.logo-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 12rpx;
}

/* 登录表单区域 */
.login-action {
  width: 100%;
}

.login-desc {
  text-align: center;
  color: rgba(255, 255, 255, 0.7);
  font-size: 28rpx;
  margin-bottom: 32rpx;
}

.login-form {
  width: 100%;
}

.form-item {
  margin-bottom: 24rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  overflow: hidden;
}

.login-tip {
  text-align: center;
  color: rgba(255, 255, 255, 0.4);
  font-size: 22rpx;
  margin-top: 24rpx;
  line-height: 1.6;
}

/* 状态区域（待审核/已停用）*/
.login-status {
  width: 100%;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.status-icon-wrap {
  margin-bottom: 24rpx;
}

.status-pending {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(232, 132, 60, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
}

.status-rejected {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: rgba(227, 77, 89, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
}

.status-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 16rpx;
}

.status-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  text-align: center;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.status-meta {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.35);
  margin-bottom: 32rpx;
}

.logout-btn {
  margin-top: 16rpx;
  color: rgba(255, 255, 255, 0.6) !important;
  border-color: rgba(255, 255, 255, 0.2) !important;
}

/* 底部 */
.login-footer {
  margin-top: auto;
  padding-top: 80rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.25);
}
