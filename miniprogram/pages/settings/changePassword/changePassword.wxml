<!--pages/settings/changePassword/changePassword.wxml-->
<view class="page-change-password">
  <view class="form-section">
    <view class="form-item">
      <text class="form-label">原密码</text>
      <t-input
        value="{{oldPassword}}"
        placeholder="请输入原密码"
        type="password"
        bind:change="onOldPasswordChange"
      />
    </view>
    <view class="form-item">
      <text class="form-label">新密码</text>
      <t-input
        value="{{newPassword}}"
        placeholder="请输入新密码（至少6位）"
        type="password"
        bind:change="onNewPasswordChange"
      />
    </view>
    <view class="form-item">
      <text class="form-label">确认新密码</text>
      <t-input
        value="{{confirmPassword}}"
        placeholder="请再次输入新密码"
        type="password"
        bind:change="onConfirmPasswordChange"
      />
    </view>
  </view>

  <view class="btn-section">
    <t-button theme="primary" block bindtap="handleSubmit" loading="{{submitting}}">
      确认修改
    </t-button>
  </view>

  <view class="tip-section">
    <text class="tip-text">忘记密码请联系管理员重置</text>
  </view>

  <watermark />
</view>
