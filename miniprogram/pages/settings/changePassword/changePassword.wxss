/* pages/settings/changePassword/changePassword.wxss */
.page-change-password {
  min-height: 100vh;
  background: #F5F7FA;
  padding: 32rpx;
  box-sizing: border-box;
}

.form-section {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #1F2937;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.btn-section {
  margin-top: 40rpx;
}

.tip-section {
  margin-top: 24rpx;
  text-align: center;
}

.tip-text {
  font-size: 24rpx;
  color: #9CA3AF;
}
