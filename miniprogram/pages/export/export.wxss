/* pages/export/export.wxss */
.page-export {
  min-height: 100vh;
  background: #F5F7FA;
}

.export-header {
  background: linear-gradient(135deg, #1E3A5F, #2A5082);
  padding: 32rpx 32rpx 40rpx;
}

.header-desc {
  color: rgba(255, 255, 255, 0.8);
  font-size: 26rpx;
  line-height: 1.6;
}

.section {
  margin: 24rpx 24rpx 0;
}

.section-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #1E3A5F;
  margin-bottom: 16rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #E8843C;
}

.card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 统计 */
.stats-row {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 48rpx;
  font-weight: bold;
  color: #1F2937;
}

.num-highlight {
  color: #E8843C;
}

.stat-label {
  font-size: 24rpx;
  color: #9CA3AF;
  margin-top: 4rpx;
}

/* 操作行 */
.action-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.action-desc {
  flex: 1;
  margin-right: 20rpx;
}

.action-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1F2937;
  margin-bottom: 4rpx;
}

.action-sub {
  font-size: 24rpx;
  color: #6B7280;
}

.action-divider {
  height: 1rpx;
  background: #F0F0F0;
  margin: 20rpx 0;
}

/* 导出历史 */
.export-history-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F7FA;
}

.export-history-item:last-child {
  border-bottom: none;
}

.eh-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.eh-name {
  font-size: 26rpx;
  color: #1F2937;
}

.eh-time {
  font-size: 22rpx;
  color: #9CA3AF;
}

/* 流程步骤 */
.flow-steps {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 8rpx 0;
}

.flow-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.flow-num {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #E8843C;
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
}

.flow-text {
  font-size: 22rpx;
  color: #4B5563;
  text-align: center;
  max-width: 140rpx;
}

.flow-arrow {
  font-size: 28rpx;
  color: #D1D5DB;
  margin: 0 4rpx;
  padding-bottom: 32rpx;
}
